<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>E-Commerce API</title>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        font-family: system-ui, sans-serif;
        background: #f5f5f5;
        color: #222;
      }
      header {
        background: #1a1a2e;
        color: #fff;
        padding: 1rem 2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
      }
      header a {
        color: #e0e0ff;
        text-decoration: none;
        font-weight: 600;
      }
      header a:hover {
        text-decoration: underline;
      }
      main {
        max-width: 1100px;
        margin: 2rem auto;
        padding: 0 1rem;
      }
      .btn {
        display: inline-block;
        padding: 0.45rem 0.9rem;
        border-radius: 4px;
        cursor: pointer;
        border: none;
        font-size: 0.9rem;
      }
      .btn-primary {
        background: #1a1a2e;
        color: #fff;
      }
      .btn-danger {
        background: #c0392b;
        color: #fff;
      }
      .btn:hover {
        opacity: 0.85;
      }
      #ws-status {
        margin-left: auto;
        font-size: 0.8rem;
        padding: 0.3rem 0.7rem;
        border-radius: 12px;
        background: #2ecc71;
        color: #fff;
      }
      #ws-status.disconnected {
        background: #e74c3c;
      }
    </style>
  </head>
  <body>
    <header>
      <a href="/products">🛒 E-Commerce</a>
      <a href="/products">Products</a>
      <a href="/carts">Find Cart</a>
      <span id="ws-status">WS: connected</span>
    </header>
    <main>
      {{{body}}}
    </main>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/realtime.js"></script>
  </body>
</html>