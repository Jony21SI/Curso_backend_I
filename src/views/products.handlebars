<style>
.filters { display: flex; gap: .75rem; align-items: flex-end; flex-wrap: wrap; margin-bottom: 1.5rem; }
.filters label { font-size: .85rem; font-weight: 600; }
.filters input, .filters select { padding: .35rem .6rem; border: 1px solid #ccc; border-radius: 4px; }
.product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1.25rem; }
.product-card { background: #fff; border-radius: 8px; box-shadow: 0 1px 4px rgba(0,0,0,.1); padding: 1rem; display: flex; flex-direction: column; gap: .5rem; }
.product-card h3 { font-size: 1rem; }
.product-card .price { font-size: 1.1rem; font-weight: 700; color: #1a1a2e; }
.product-card .category { font-size: .8rem; color: #777; }
.product-card .stock { font-size: .8rem; }
.product-card .actions { margin-top: auto; display: flex; gap: .5rem; }
.pagination { display: flex; align-items: center; gap: 1rem; margin-top: 2rem; justify-content: center; }
.pagination a { padding: .4rem .9rem; background: #1a1a2e; color: #fff; border-radius: 4px; text-decoration: none; }
.pagination a:hover { opacity: .85; }
.pagination span { font-size: .9rem; color: #555; }
#realtime-banner { display: none; background: #2ecc71; color: #fff; padding: .6rem 1rem; border-radius: 6px; margin-bottom: 1rem; }
</style>

<div id="realtime-banner">A product was updated — <a href="" style="color:#fff;font-weight:700">Reload to see changes</a></div>

<h2 style="margin-bottom:1rem">Products</h2>

<form class="filters" method="get" action="/products">
    <div>
        <label for="query-input">Category / Status</label><br/>
        <input id="query-input" name="query" type="text" placeholder="e.g. electronics" value="{{query}}" />
    </div>
    <div>
        <label for="sort-select">Sort by price</label><br/>
        <select id="sort-select" name="sort">
            <option value="">None</option>
            <option value="asc" {{#if (eq sort "asc")}}selected{{/if}}>Asc</option>
            <option value="desc" {{#if (eq sort "desc")}}selected{{/if}}>Desc</option>
        </select>
    </div>
    <div>
        <label for="limit-select">Per page</label><br/>
        <select id="limit-select" name="limit">
            <option value="5">5</option>
            <option value="10" selected>10</option>
            <option value="20">20</option>
        </select>
    </div>
    <button type="submit" class="btn btn-primary">Filter</button>
</form>

<div class="product-grid" id="product-list">
    {{#each products}}
    <div class="product-card" id="product-{{_id}}">
        <h3><a href="/products/{{_id}}">{{title}}</a></h3>
        <span class="category">{{category}}</span>
        <span class="price">${{price}}</span>
        <span class="stock">Stock: {{stock}}</span>
        <div class="actions">
            <a href="/products/{{_id}}" class="btn btn-primary">Details</a>
        </div>
    </div>
    {{else}}
    <p>No products found.</p>
    {{/each}}
</div>

<div class="pagination">
    {{#if hasPrevPage}}<a href="{{prevLink}}">← Prev</a>{{/if}}
    <span>Page {{page}} of {{totalPages}}</span>
    {{#if hasNextPage}}<a href="{{nextLink}}">Next →</a>{{/if}}
</div>
